# ============================================================
# Keevan Store — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit your real .env file to version control
# ============================================================

# ── Database (Prisma local dev) ─────────────────────────────
DATABASE_URL=file:./db/custom.db

# ── Supabase ────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Cloudflare R2 Storage ───────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=keevanstore

# ── Pesapal Payments (API v3.0) ─────────────────────────────
# Get credentials from: https://developer.pesapal.com/api3-demo-keys.txt (sandbox)
PESAPAL_CONSUMER_KEY=your-pesapal-consumer-key
PESAPAL_CONSUMER_SECRET=your-pesapal-consumer-secret
PESAPAL_IPN_ID=your-pesapal-ipn-id  # Run POST /api/pesapal/register-ipn to get this
PESAPAL_IPN_URL=https://yourdomain.com/api/pesapal/ipn
PESAPAL_CALLBACK_URL=https://yourdomain.com/api/pesapal/callback
PESAPAL_ENV=sandbox  # Change to "live" for production

# ── Application ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.keevanstore.in
ADMIN_WHATSAPP_NUMBER=256768345905
