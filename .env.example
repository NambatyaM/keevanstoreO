# =============================================================================
# Keevan Store — Required Environment Variables
# =============================================================================
# Copy this file to .env and fill in all values before deploying.
#   cp .env.example .env
# =============================================================================

# ----- Database (required for running migrations) -----
# Find this in Supabase Dashboard → Project Settings → Database → Connection string
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ----- Supabase (required for app to function) -----
# Project URL: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
# anon public key (safe for client-side use)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# service_role key (server-side only — never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# ----- Site Configuration -----
# Must be the canonical production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://keevanstore.in
# Override platform defaults (optional — use Supabase platform_config table for DB-backed values)
NEXT_PUBLIC_SUPPORT_PHONE=+256768345905
NEXT_PUBLIC_SUPPORT_WHATSAPP=https://wa.me/256768345905
NEXT_PUBLIC_COMMISSION_RATE=0.1
NEXT_PUBLIC_MIN_WITHDRAWAL=50000

# ----- Pesapal Payment Gateway (required for payments) -----
# Obtain from your Pesapal developer dashboard
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
# IPN (Instant Payment Notification) ID registered with Pesapal
PESAPAL_IPN_ID=
# Use https://pay.pesapal.com/v3 for production, https://cybqa.pesapal.com/pesapalv3 for sandbox
PESAPAL_BASE_URL=https://pay.pesapal.com/v3
# Webhook secret for verifying Pesapal IPN callbacks
WEBHOOK_SECRET=

# ----- SMTP (required for transactional emails) -----
# Configure SMTP in Supabase Dashboard (Settings → Auth → SMTP)
# Then use the same credentials here:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@keevanstore.in

# ----- Vercel Cron Secret (required for automated email processing) -----
# Generate a random 64-character hex string. Set this both in .env and in
# Vercel Environment Variables (Settings → Environment Variables) so that
# Cron Jobs can authenticate with the /api/cron/process-emails endpoint.
CRON_SECRET=

# ----- Admin Credentials (for seeding the first admin user) -----
# Used by `npm run seed:admin` to create the initial admin account.
# The admin user has full access to the admin dashboard, refund approval,
# withdrawal management, and audit log viewing.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# ----- Sentry Error Monitoring (optional but recommended) -----
# Obtain from https://sentry.io
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
