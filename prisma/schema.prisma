// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Creator {
  id              String   @id @default(cuid())
  email           String   @unique
  username        String   @unique
  displayName     String
  bio             String   @default("")
  photoUrl        String?
  bannerUrl       String?
  socialLinks     String   @default("[]") // JSON string
  donationsEnabled Boolean  @default(false)
  donationGoal    Int?
  donationCurrent Int      @default(0)
  balance         Int      @default(0)
  totalEarnings   Int      @default(0)
  totalSales      Int      @default(0)
  totalViews      Int      @default(0)
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  isAdmin         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  products        Product[]
  orders          Order[]
}

model Product {
  id          String   @id @default(cuid())
  creatorId   String
  creator     Creator  @relation(fields: [creatorId], references: [id])
  title       String
  slug        String
  description String   @default("")
  price       Int
  currency    String   @default("UGX")
  type        String   @default("digital") // digital, event
  status      String   @default("active") // active, inactive
  thumbnailUrl String?
  fileUrl     String?
  fileName    String?
  fileSize    Int?
  venue       String?
  eventDate   DateTime?
  capacity    Int?
  ticketsSold Int      @default(0)
  views       Int      @default(0)
  salesCount  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([creatorId, slug])
  downloadSessions DownloadSession[]
}

model Order {
  id                     String   @id @default(cuid())
  creatorId              String
  creator                Creator  @relation(fields: [creatorId], references: [id])
  productId              String?  // nullable for donations
  buyerEmail             String
  buyerName              String
  amount                 Int
  platformFee            Int      @default(0)
  creatorEarning         Int      @default(0)
  currency               String   @default("UGX")
  status                 String   @default("pending") // pending, completed, failed, refunded
  paymentMethod          String   @default("mtn_momo")
  pesapalOrderTrackingId String?
  pesapalTransactionId   String?
  downloadToken          String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  downloadSessions       DownloadSession[]
}

model PageView {
  id        String   @id @default(cuid())
  creatorId String
  page      String
  referrer  String?
  createdAt DateTime @default(now())
}

model Donation {
  id        String   @id @default(cuid())
  creatorId String
  donorEmail String
  donorName  String
  amount     Int
  message    String   @default("")
  anonymous  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Withdrawal {
  id              String   @id @default(cuid())
  creatorId       String
  amount          Int
  method          String   @default("mobile_money") // mobile_money, bank_transfer
  accountDetails  String   @default("{}") // JSON string with phoneNumber, provider
  status          String   @default("pending") // pending, approved, rejected, paid
  adminNotes      String?
  createdAt       DateTime @default(now()) @map("requested_at")
  processedAt     DateTime?

  @@map("withdrawals")
}

model Ticket {
  id           String   @id @default(cuid())
  orderId      String
  eventId      String
  buyerEmail   String?  @map("buyer_email")
  buyerName    String?  @map("buyer_name")
  qrCodeData   String   @map("qr_code_data")
  checkedIn    Boolean  @default(false) @map("checked_in")
  checkedInAt  DateTime? @map("checked_in_at")

  @@map("tickets")
}

model DownloadSession {
  id              String    @id @default(cuid())
  orderId         String
  productId       String
  downloadToken   String    @unique
  expiresAt       DateTime
  downloadCount   Int       @default(0)
  maxDownloads    Int       @default(5)
  lastDownloadedAt DateTime?
  createdAt       DateTime  @default(now())

  order           Order     @relation(fields: [orderId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
}

model Event {
  id          String   @id @default(cuid())
  productId   String
  venue       String
  eventDate   DateTime
  capacity    Int
  ticketsSold Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("events")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
