// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
// FIXED: Blueprint Issue C — Added cascade deletes on relational models,
// added PlatformConfig model for persistent platform-level settings.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Creator {
  id              String   @id @default(cuid())
  email           String   @unique
  username        String   @unique
  displayName     String
  bio             String   @default("")
  photoUrl        String?
  bannerUrl       String?
  socialLinks     String   @default("[]") // JSON string
  donationsEnabled Boolean  @default(false)
  donationGoal    Int?
  donationCurrent Int      @default(0)
  balance         Int      @default(0)
  totalEarnings   Int      @default(0)
  totalSales      Int      @default(0)
  totalViews      Int      @default(0)
  isActive        Boolean  @default(true)
  isVerified      Boolean  @default(false)
  isAdmin         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // FIXED: cascade delete — deleting a creator removes all their data
  products    Product[]
  orders      Order[]
  withdrawals Withdrawal[]
  donations   Donation[]
  pageViews   PageView[]
}

model Product {
  id           String    @id @default(cuid())
  creatorId    String
  // FIXED: cascade delete — deleting a creator removes their products
  creator      Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  title        String
  slug         String
  description  String    @default("")
  price        Int
  currency     String    @default("UGX")
  type         String    @default("digital") // digital, event
  status       String    @default("active")  // active, inactive
  thumbnailUrl String?
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  venue        String?
  eventDate    DateTime?
  capacity     Int?
  ticketsSold  Int       @default(0)
  views        Int       @default(0)
  salesCount   Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([creatorId, slug])
  downloadSessions DownloadSession[]
  events           Event[]
}

model Order {
  id                     String    @id @default(cuid())
  creatorId              String
  // FIXED: cascade delete — deleting a creator removes their orders
  creator                Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  productId              String?   // nullable for donations
  buyerEmail             String
  buyerName              String
  amount                 Int
  platformFee            Int       @default(0)
  creatorEarning         Int       @default(0)
  currency               String    @default("UGX")
  status                 String    @default("pending") // pending, completed, failed, refunded
  paymentMethod          String    @default("mtn_momo")
  pesapalOrderTrackingId String?
  pesapalTransactionId   String?
  downloadToken          String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  // FIXED: cascade delete — deleting an order removes associated sessions
  downloadSessions DownloadSession[]
  tickets          Ticket[]
}

model PageView {
  id           String   @id @default(cuid())
  creatorId    String
  // FIXED: cascade delete
  creator      Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  productId    String?
  viewType     String   @default("store") // store, product
  viewerIpHash String?
  referrer     String?
  createdAt    DateTime @default(now())
}

model Donation {
  id         String   @id @default(cuid())
  creatorId  String
  // FIXED: cascade delete
  creator    Creator  @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  orderId    String?
  donorEmail String
  donorName  String
  amount     Int
  message    String   @default("")
  anonymous  Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Withdrawal {
  id             String    @id @default(cuid())
  creatorId      String
  // FIXED: cascade delete
  creator        Creator   @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  amount         Int
  method         String    @default("mobile_money") // mobile_money, bank_transfer
  accountDetails String    @default("{}") // JSON string with phoneNumber, provider
  status         String    @default("pending") // pending, approved, rejected, paid
  adminNotes     String?
  createdAt      DateTime  @default(now()) @map("requested_at")
  processedAt    DateTime?

  @@map("withdrawals")
}

model Ticket {
  id          String    @id @default(cuid())
  orderId     String    @map("order_id")
  // FIXED: cascade delete — deleting an order removes its tickets
  order       Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  eventId     String    @map("event_id")
  buyerEmail  String?   @map("buyer_email")
  buyerName   String?   @map("buyer_name")
  qrCodeData  String    @map("qr_code_data")
  checkedIn   Boolean   @default(false) @map("checked_in")
  checkedInAt DateTime? @map("checked_in_at")

  @@map("tickets")
}

model DownloadSession {
  id               String    @id @default(cuid())
  orderId          String
  // FIXED: cascade delete — deleting an order removes its download sessions
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String
  // FIXED: cascade delete — deleting a product removes its download sessions
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadToken    String    @unique
  expiresAt        DateTime
  downloadCount    Int       @default(0)
  maxDownloads     Int       @default(5)
  lastDownloadedAt DateTime?
  createdAt        DateTime  @default(now())
}

model Event {
  id          String   @id @default(cuid())
  productId   String
  // FIXED: cascade delete — deleting a product removes its event record
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  venue       String
  eventDate   DateTime
  capacity    Int
  ticketsSold Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("events")
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String   @default("")
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

// FIXED: Blueprint Issue C — PlatformConfig model for persistent
// platform-wide settings that must survive deployments (IPN ID, fee rates).
model PlatformConfig {
  id        String   @id @default("singleton") // Single row enforced by fixed ID
  // Pesapal IPN registration ID — cached here so re-deploys don't re-register
  ipnId     String?
  ipnUrl    String?
  // Platform fee override (defaults to PLATFORM_FEE_PERCENT constant if null)
  feePercent Int?
  updatedAt DateTime @updatedAt

  @@map("platform_config")
}
